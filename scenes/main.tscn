[gd_scene load_steps=8 format=3 uid="uid://main"]

[ext_resource type="Script" path="res://scripts/main.gd" id="1"]
[ext_resource type="PackedScene" uid="uid://hud" path="res://scenes/hud.tscn" id="2"]
[ext_resource type="AudioStream" path="res://assets/sounds/game_over.wav" id="3"]
[ext_resource type="AudioStream" path="res://assets/music/bgm_extended.wav" id="4"]
[ext_resource type="AudioStream" path="res://assets/music/intermission_bgm.wav" id="5"]
[ext_resource type="Shader" path="res://shaders/screen_effects.gdshader" id="6"]

[sub_resource type="ShaderMaterial" id="ShaderMaterial_screen"]
shader = ExtResource("6")
shader_parameter/chromatic_aberration = 0.0
shader_parameter/distortion = 0.04

[node name="Main" type="Node2D"]
script = ExtResource("1")

[node name="SpawnTimer" type="Timer" parent="."]
wait_time = 3.0
autostart = false
one_shot = true

[node name="ScreenShaderLayer" type="CanvasLayer" parent="."]
layer = 1

[node name="BackBufferCopy" type="BackBufferCopy" parent="ScreenShaderLayer"]
copy_mode = 2

[node name="ScreenEffects" type="ColorRect" parent="ScreenShaderLayer"]
material = SubResource("ShaderMaterial_screen")
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
mouse_filter = 2

[node name="HUD" parent="." instance=ExtResource("2")]

[node name="BGM" type="AudioStreamPlayer" parent="."]
stream = ExtResource("4")
volume_db = -8.0

[node name="IntermissionBGM" type="AudioStreamPlayer" parent="."]
stream = ExtResource("5")
volume_db = -10.0

[node name="GameOverSound" type="AudioStreamPlayer" parent="."]
stream = ExtResource("3")

[connection signal="timeout" from="SpawnTimer" to="." method="_on_countdown_done"]
[connection signal="finished" from="BGM" to="." method="_on_bgm_finished"]
[connection signal="finished" from="IntermissionBGM" to="." method="_on_intermission_bgm_finished"]
